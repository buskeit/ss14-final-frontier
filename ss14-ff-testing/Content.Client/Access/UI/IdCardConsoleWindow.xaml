<DefaultWindow xmlns="https://spacestation14.io"
            xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
            SetSize="700 600"
            MinSize="700 600">
        <BoxContainer Orientation="Vertical" VerticalExpand="True" VerticalAlignment="Top" MinHeight="550">
            <!-- Privileged and target IDs, crew manifest button. -->
            <GridContainer Columns="2">
                <GridContainer Columns="3" HorizontalExpand="True">
                    <Label Text="{Loc 'id-card-console-window-privileged-id'}" StyleClasses="LabelKeyText"/>
                    <Button Name="PrivilegedIdButton" Access="Public"/>
                    <Label Name="PrivilegedIdLabel" />

                    <Label Text="{Loc 'id-card-console-window-target-id'}" StyleClasses="LabelKeyText"/>
                    <Button Name="TargetIdButton" Access="Public"/>
                    <Label Name="TargetIdLabel" />
                </GridContainer>
                <BoxContainer Orientation="Vertical">
                    <Button Name="CrewManifestButton" Access="Public" Text="{Loc 'crew-manifest-button-label'}" />
                </BoxContainer>

            </GridContainer>
            <Control MinSize="0 8" />
            <!-- Full name and job title editing. -->
            <GridContainer Columns="3" HSeparationOverride="4">
                <Label Name="FullNameLabel" Text="{Loc 'id-card-console-window-full-name-label'}" />
                <LineEdit Name="FullNameLineEdit" HorizontalExpand="True" />
                <Button Name="FullNameSaveButton" Text="Search" Disabled="True" />
            </GridContainer>
            <BoxContainer Orientation="Horizontal">
                <Label Text="Selected Account:"
                 StyleClasses="LabelKeyText"/>
                <Control MinSize="8 0" />
                <Label Name="SelectedAccountLabel" />
            </BoxContainer>
            <TabContainer VerticalExpand="True" Name="MainTabs">
                <BoxContainer Orientation="Vertical" Name="AccountDetails" VerticalExpand="True">
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="Spending:"
                         StyleClasses="LabelKeyText"/>
                        <Control MinSize="8 0" />
                        <Label Name="SpendingLabel" />
                        <Control HorizontalExpand="True" />
                        <Button Name="SpendingReset" Text="Refresh Spending" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="Assignment:"
                         StyleClasses="LabelKeyText"/>
                        <Control MinSize="8 0" />
                        <Label Name="AssignmentLabel"/>
                    </BoxContainer>
                    <Control MinSize="0 8" />
                    <!-- Job preset selection, grant/revoke all access buttons. -->
                    <!-- Individual assignment buttons -->
                    <PanelContainer VerticalExpand="True"
                                                        HorizontalExpand="True"
                                                   SizeFlagsStretchRatio="1"
                                                   Name="AssignmentAccessesPC">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#000000" />
                        </PanelContainer.PanelOverride>
                        <WrapContainer Name="AccessLevelControlContainer" />
                    </PanelContainer>
                </BoxContainer>
                
                <BoxContainer Orientation="Vertical" Name="GeneralRecord" VerticalExpand="True">
                    <TabContainer VerticalExpand="True" Name="GeneralTabs">

                        <BoxContainer Orientation="Vertical" Name="ViewGeneralRecord" VerticalExpand="True">
                            <Button Name="PrintGeneralRecordBtn" Access="Public" Text="Print Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer VerticalExpand="True"  HorizontalExpand="True" SizeFlagsStretchRatio="1">
                                <ScrollContainer>
                                    <Control MinSize="0 8" />
                                    <RichTextLabel Name="GeneralRecordLabel" VerticalAlignment="Top"></RichTextLabel>
                                </ScrollContainer>
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#000000" />
                                </PanelContainer.PanelOverride>

                            </PanelContainer>
                        </BoxContainer>

                        <BoxContainer Orientation="Vertical" Name="EditGeneralRecord" VerticalExpand="True">
                            <Button Name="SaveGeneralRecordBtn" Access="Public" Text="Save Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer StyleIdentifier="PaperEditBackground" VerticalExpand="True" HorizontalExpand="True">
                                <TextEdit Name="GeneralRecordTE"  Access="Public" HorizontalExpand="True" VerticalExpand="True"/>
                            </PanelContainer>
                        </BoxContainer>
                    </TabContainer>
                </BoxContainer>

                <BoxContainer Orientation="Vertical" Name="CriminalRecord" VerticalExpand="True">
                    <TabContainer VerticalExpand="True" Name="CriminalTabs">

                        <BoxContainer Orientation="Vertical" Name="ViewCriminalRecord" VerticalExpand="True">
                            <Button Name="PrintCriminalRecordBtn" Access="Public" Text="Print Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer VerticalExpand="True"  HorizontalExpand="True" SizeFlagsStretchRatio="1">
                                <ScrollContainer>
                                    <Control MinSize="0 8" />
                                    <RichTextLabel Name="CriminalRecordLabel" VerticalAlignment="Top"></RichTextLabel>
                                </ScrollContainer>
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#000000" />
                                </PanelContainer.PanelOverride>

                            </PanelContainer>
                        </BoxContainer>

                        <BoxContainer Orientation="Vertical" Name="EditCriminalRecord" VerticalExpand="True">
                            <Button Name="SaveCriminalRecordBtn" Access="Public" Text="Save Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer StyleIdentifier="PaperEditBackground" VerticalExpand="True" HorizontalExpand="True">
                                <TextEdit Name="CriminalRecordTE"  Access="Public" HorizontalExpand="True" VerticalExpand="True"/>
                            </PanelContainer>
                        </BoxContainer>
                    </TabContainer>
                </BoxContainer>
                
                <BoxContainer Orientation="Vertical" Name="MedicalRecord" VerticalExpand="True">
                    <TabContainer VerticalExpand="True" Name="MedicalTabs">

                        <BoxContainer Orientation="Vertical" Name="ViewMedicalRecord" VerticalExpand="True">
                            <Button Name="PrintMedicalRecordBtn" Access="Public" Text="Print Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer VerticalExpand="True"  HorizontalExpand="True" SizeFlagsStretchRatio="1">
                                <ScrollContainer>
                                    <Control MinSize="0 8" />
                                    <RichTextLabel Name="MedicalRecordLabel" VerticalAlignment="Top"></RichTextLabel>
                                </ScrollContainer>
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#000000" />
                                </PanelContainer.PanelOverride>

                            </PanelContainer>
                        </BoxContainer>

                        <BoxContainer Orientation="Vertical" Name="EditMedicalRecord" VerticalExpand="True">
                            <Button Name="SaveMedicalRecordBtn" Access="Public" Text="Save Record"/>
                            <Control MinSize="0 8" />
                            <PanelContainer StyleIdentifier="PaperEditBackground" VerticalExpand="True" HorizontalExpand="True">
                                <TextEdit Name="MedicalRecordTE"  Access="Public" HorizontalExpand="True" VerticalExpand="True"/>
                            </PanelContainer>
                        </BoxContainer>
                    </TabContainer>
                </BoxContainer>
                
            </TabContainer>

        </BoxContainer>
            
</DefaultWindow>
